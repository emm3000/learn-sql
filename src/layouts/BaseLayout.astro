---
import { SITE_NAME } from '../lib/site.ts';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
}

const { title, description, canonical } = Astro.props;

// Cloudflare Web Analytics beacon (cookieless) — NFR-11. The token is set
// per-environment via PUBLIC_CF_BEACON_TOKEN; when absent (e.g. local dev) the
// beacon is omitted. Do NOT also enable dashboard auto-injection on Cloudflare
// Pages with this present — that double-counts page views.
const cfBeaconToken = import.meta.env.PUBLIC_CF_BEACON_TOKEN;

const fullTitle = title === SITE_NAME ? SITE_NAME : `${title} — ${SITE_NAME}`;

let canonicalURL: string;
if (canonical) {
  canonicalURL = canonical;
} else if (Astro.site) {
  canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
} else {
  canonicalURL = Astro.url.pathname;
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content={SITE_NAME} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />

    <meta name="generator" content={Astro.generator} />

    {
      cfBeaconToken && (
        <script
          is:inline
          defer
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={JSON.stringify({ token: cfBeaconToken })}
        />
      )
    }
    <slot name="head" />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <slot />
  </body>
</html>
