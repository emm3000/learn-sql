---
interface Props {
  title: string;
  description: string;
  canonical?: string;
}

// Placeholder product name pending final naming (PRD Q1).
// This is the ONLY place the product name lives.
const SITE_NAME = 'Postgres Playground';

const { title, description, canonical } = Astro.props;

// Cloudflare Web Analytics beacon (cookieless) — NFR-11. The token is set
// per-environment via PUBLIC_CF_BEACON_TOKEN; when absent (e.g. local dev) the
// beacon is omitted. Do NOT also enable dashboard auto-injection on Cloudflare
// Pages with this present — that double-counts page views.
const cfBeaconToken = import.meta.env.PUBLIC_CF_BEACON_TOKEN;

const fullTitle = title === SITE_NAME ? SITE_NAME : `${title} — ${SITE_NAME}`;

let canonicalURL: string;
if (canonical) {
  canonicalURL = canonical;
} else if (Astro.site) {
  canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
} else {
  canonicalURL = Astro.url.pathname;
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:site_name" content={SITE_NAME} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />

    <meta name="generator" content={Astro.generator} />

    {
      cfBeaconToken && (
        <script
          is:inline
          defer
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={JSON.stringify({ token: cfBeaconToken })}
        />
      )
    }
    <slot name="head" />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <slot />
  </body>
</html>

<style is:global>
  body {
    font-family: system-ui, sans-serif;
    margin: 0;
    padding: 24px;
    background: #f9fafb;
    color: #111827;
  }

  /* Tighten edge padding on phones so content keeps its width (NFR-10). */
  @media (max-width: 480px) {
    body {
      padding: 16px;
    }
  }

  :focus-visible {
    outline: 2px solid #2563eb;
    outline-offset: 2px;
  }

  .skip-link {
    position: absolute;
    left: 8px;
    top: -48px;
    z-index: 100;
    padding: 8px 12px;
    background: #2563eb;
    color: #fff;
    border-radius: 0 0 6px 6px;
    text-decoration: none;
    transition: top 0.15s;
  }

  .skip-link:focus {
    top: 0;
  }
</style>
