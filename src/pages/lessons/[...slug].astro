---
import { getCollection, render } from 'astro:content';
import LessonExercises from '../../components/LessonExercises.svelte';
import LessonRailProgress from '../../components/LessonRailProgress.svelte';
import { exercisesByLesson } from '../../lib/exercises/index.ts';
import { belts } from '../../lib/belts.ts';
import { parseSeedSchema } from '../../lib/schema/parse-seed.ts';
import seedSql from '../../../seed/classic_company.sql?raw';
import BaseLayout from '../../layouts/BaseLayout.astro';
import '../../styles/lesson.css';

export async function getStaticPaths() {
  const lessons = await getCollection('lessons', ({ data }) => !data.draft);
  return lessons.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { slug } = Astro.params;
const { Content } = await render(entry);

const exercises = exercisesByLesson[slug] ?? [];

// Resolve belt
const belt = belts.find((b) => b.id === entry.data.belt) ?? belts[0];

// Sibling lessons in the same belt, sorted by per-belt order
const allLessons = await getCollection('lessons', ({ data }) => !data.draft);
const siblingLessons = allLessons
  .filter((l) => l.data.belt === entry.data.belt)
  .map((l) => ({
    slug: l.id,
    title: l.data.title,
    order: l.data.order,
    exerciseCount: exercisesByLesson[l.id]?.length ?? 0,
  }))
  .sort((a, b) => a.order - b.order);

// Current lesson's position (1-based)
const lessonIndex = siblingLessons.findIndex((l) => l.slug === slug);
const lessonNumber = lessonIndex + 1;
const lessonTotal = siblingLessons.length;
const nextLesson =
  lessonIndex >= 0 && lessonIndex < siblingLessons.length - 1
    ? siblingLessons[lessonIndex + 1]
    : null;

// Schema rail — parsed from the real seed at build time
const schema = parseSeedSchema(seedSql);
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <div class="lesson-root" style={`--c: ${belt.color}; --cink: ${belt.ink}`}>
    <!-- Lesson nav bar -->
    <header class="lnav">
      <a href="/" class="lnav-back" aria-label="Back to belt map">
        <svg
          width="14"
          height="14"
          viewBox="0 0 16 16"
          fill="none"
          aria-hidden="true"
        >
          <path
            d="M13 8H3.5M7 4l-3.5 4L7 12"
            stroke="currentColor"
            stroke-width="1.5"
            stroke-linecap="round"
            stroke-linejoin="round"></path>
        </svg>
        Belt map
      </a>

      <div class="lnav-mid">
        <span class="lnav-belt">
          <span class="lnav-belt-dot" aria-hidden="true"></span>
          {belt.name} belt
        </span>
        <span class="lnav-sep" aria-hidden="true">/</span>
        <span class="lnav-lesson">
          Lesson {lessonNumber} · {entry.data.title}
        </span>
      </div>

      <nav class="lnav-dots" aria-label="Lessons in this belt">
        {
          siblingLessons.map((l) => (
            <a
              href={`/lessons/${l.slug}`}
              class={`lnav-dot${l.slug === slug ? ' on' : ''}`}
              aria-label={`Lesson ${l.order}: ${l.title}`}
              title={l.title}
            />
          ))
        }
      </nav>
    </header>

    <!-- Two-column grid -->
    <div class="lesson-grid">
      <!-- Reading column -->
      <main id="main-content" class="reading" tabindex="-1">
        <div class="lesson-top">
          <span class="lesson-kicker">
            <span class="lk-dot" aria-hidden="true"></span>
            {belt.name} · Lesson {lessonNumber} of {lessonTotal}
          </span>
          <h1 class="lesson-h">{entry.data.title}</h1>
          <p class="lesson-dek">{entry.data.description}</p>
        </div>

        <article class="prose">
          <Content />
        </article>

        <section class="exercises-section" aria-label="Exercises">
          <LessonExercises
            lessonSlug={slug}
            {exercises}
            {seedSql}
            beltColor={belt.color}
            beltInk={belt.ink}
            client:only="svelte"
          />
        </section>

        <nav class="lesson-foot" aria-label="Lesson navigation">
          <a href="/" class="btn">
            <svg
              width="14"
              height="14"
              viewBox="0 0 16 16"
              fill="none"
              aria-hidden="true"
            >
              <path
                d="M13 8H3.5M7 4l-3.5 4L7 12"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
            Belt map
          </a>
          {
            nextLesson ? (
              <a href={`/lessons/${nextLesson.slug}`} class="btn btn-primary">
                Next lesson: {nextLesson.title}
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 16 16"
                  fill="none"
                  aria-hidden="true"
                >
                  <path
                    d="M3 8h9M8.5 4.5L12 8l-3.5 3.5"
                    stroke="currentColor"
                    stroke-width="1.6"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </a>
            ) : (
              <a href="/" class="btn btn-primary">
                Back to belt map
                <svg
                  width="14"
                  height="14"
                  viewBox="0 0 16 16"
                  fill="none"
                  aria-hidden="true"
                >
                  <path
                    d="M3 8h9M8.5 4.5L12 8l-3.5 3.5"
                    stroke="currentColor"
                    stroke-width="1.6"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </a>
            )
          }
        </nav>
      </main>

      <!-- Rail (schema + belt progress) -->
      <aside class="rail" aria-label="Reference panel">
        <div class="rail-sticky">
          <!-- Schema cards — all 7 tables -->
          <div class="schema-cards">
            {
              schema.map((t) => (
                <div class="schema">
                  <div class="schema-head">
                    <svg
                      width="13"
                      height="13"
                      viewBox="0 0 16 16"
                      fill="none"
                      aria-hidden="true"
                    >
                      <rect
                        x="2.5"
                        y="3"
                        width="11"
                        height="10"
                        rx="1.5"
                        stroke="currentColor"
                        stroke-width="1.3"
                      />
                      <path
                        d="M2.5 6.5h11M6.5 6.5V13"
                        stroke="currentColor"
                        stroke-width="1.3"
                      />
                    </svg>
                    <span class="schema-name">{t.table}</span>
                    <span class="schema-cols-count">
                      {t.columns.length} cols
                    </span>
                  </div>
                  <ul class="schema-cols">
                    {t.columns.map((col) => (
                      <li>
                        <span class="sc-name">{col.name}</span>
                        <span class="sc-type">{col.type}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              ))
            }
          </div>

          <!-- Belt progress island -->
          <LessonRailProgress
            beltName={belt.name}
            beltColor={belt.color}
            beltInk={belt.ink}
            lessons={siblingLessons}
            currentSlug={slug}
            client:only="svelte"
          />
        </div>
      </aside>
    </div>
  </div>
</BaseLayout>
