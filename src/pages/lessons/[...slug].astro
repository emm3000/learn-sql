---
import { getCollection, render } from 'astro:content';
import LessonExercises from '../../components/LessonExercises.svelte';
import { exercisesByLesson } from '../../lib/exercises/index.ts';
import seedSql from '../../../seed/classic_company.sql?raw';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const lessons = await getCollection('lessons', ({ data }) => !data.draft);
  return lessons.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { slug } = Astro.params;
const { Content } = await render(entry);

const exercises = exercisesByLesson[slug] ?? [];
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/" class="back-link">&#8592; Belts</a>
  </nav>
  <header>
    <h1>{entry.data.title}</h1>
    <p>{entry.data.description}</p>
  </header>
  <main id="main-content" tabindex="-1">
    <article class="lesson-prose">
      <Content />
    </article>
    <LessonExercises
      lessonSlug={slug}
      {exercises}
      {seedSql}
      client:only="svelte"
    />
  </main>
</BaseLayout>

<style>
  .breadcrumb {
    margin-bottom: 16px;
  }

  .back-link {
    font-size: 14px;
    color: #2563eb;
    text-decoration: none;
    font-weight: 500;
  }

  .back-link:hover {
    text-decoration: underline;
  }

  header {
    margin-bottom: 24px;
  }

  h1 {
    font-size: 24px;
    font-weight: 700;
    margin: 0 0 6px;
    color: #111827;
  }

  header p {
    margin: 0;
    color: #6b7280;
    font-size: 15px;
  }

  main {
    /* TODO(reskin): temporary gutter until this page is reskinned */
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 10px;
    padding: 20px;
    max-width: 960px;
    margin: 24px auto;
    width: calc(100% - 32px);
  }

  .lesson-prose {
    line-height: 1.7;
    color: #1f2937;
  }

  .lesson-prose :global(h2) {
    font-size: 18px;
    font-weight: 700;
    margin: 24px 0 8px;
    color: #111827;
  }

  .lesson-prose :global(h3) {
    font-size: 16px;
    font-weight: 600;
    margin: 20px 0 6px;
    color: #111827;
  }

  .lesson-prose :global(p) {
    margin: 0 0 14px;
  }

  .lesson-prose :global(pre) {
    background: #f3f4f6;
    border: 1px solid #e5e7eb;
    border-radius: 6px;
    padding: 12px 16px;
    overflow-x: auto;
    font-size: 13px;
    line-height: 1.6;
    margin: 0 0 14px;
  }

  .lesson-prose :global(code) {
    font-family: ui-monospace, monospace;
  }

  .lesson-prose :global(ul),
  .lesson-prose :global(ol) {
    margin: 0 0 14px;
    padding-left: 24px;
  }

  .lesson-prose :global(li) {
    margin-bottom: 4px;
  }
</style>
