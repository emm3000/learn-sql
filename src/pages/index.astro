---
import { getCollection } from 'astro:content';
import { belts } from '../lib/belts.ts';
import { exercisesByLesson } from '../lib/exercises/index.ts';
import BeltLessons from '../components/BeltLessons.svelte';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_NAME } from '../lib/site.ts';

// Build a per-belt lesson lookup: group all non-draft lessons by belt,
// sorted by per-belt order (each belt's order starts at 1 independently).
const allLessons = await getCollection('lessons', ({ data }) => !data.draft);
const lessonsByBelt = allLessons.reduce<Record<string, { slug: string; title: string; order: number; exerciseCount: number }[]>>(
  (acc, entry) => {
    const beltId = entry.data.belt;
    if (!acc[beltId]) acc[beltId] = [];
    acc[beltId].push({
      slug: entry.id,
      title: entry.data.title,
      order: entry.data.order,
      exerciseCount: exercisesByLesson[entry.id]?.length ?? 0,
    });
    return acc;
  },
  {},
);
// Sort each belt's lessons by their per-belt order.
for (const beltId of Object.keys(lessonsByBelt)) {
  lessonsByBelt[beltId].sort((a, b) => a.order - b.order);
}
---

<BaseLayout
  title="Learn PostgreSQL in the browser"
  description="Learn PostgreSQL by writing real SQL — no setup, no account, runs in your browser."
>
    <header class="site-header">
      <h1>{SITE_NAME}</h1>
      <p class="site-tagline">
        Learn PostgreSQL by writing real SQL — no setup, no account, runs in
        your browser.
      </p>
    </header>

    <main id="main-content" tabindex="-1">
      <h2 class="path-heading">Your Learning Path</h2>
      <ol class="belt-list">
        {
          belts.map((belt) => (
            <li
              class={`belt-card ${belt.status === 'coming-soon' ? 'belt-card--coming-soon' : ''}`}
              style={`--belt-color: ${belt.color};`}
            >
              <div class="belt-card-header">
                <div class="belt-indicator" aria-hidden="true" />
                <div class="belt-meta">
                  <h3 class="belt-name">{belt.name}</h3>
                  <p class="belt-subtitle">{belt.subtitle}</p>
                </div>
                {belt.status === 'coming-soon' && (
                  <span class="coming-soon-badge">Coming soon</span>
                )}
              </div>

              {belt.status === 'active' && (
                <div class="belt-lessons">
                  <BeltLessons lessons={lessonsByBelt[belt.id] ?? []} client:load />
                </div>
              )}
            </li>
          ))
        }
      </ol>
    </main>
</BaseLayout>

<style>
  .site-header {
    margin-bottom: 32px;
    max-width: 720px;
  }

  h1 {
    font-size: 28px;
    font-weight: 800;
    margin: 0 0 8px;
    color: #111827;
  }

  .site-tagline {
    margin: 0;
    color: #6b7280;
    font-size: 16px;
    line-height: 1.5;
  }

  .path-heading {
    font-size: 18px;
    font-weight: 700;
    color: #374151;
    margin: 0 0 16px;
  }

  .belt-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
    max-width: 720px;
  }

  .belt-card {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-left: 4px solid var(--belt-color);
    border-radius: 10px;
    padding: 20px;
  }

  .belt-card--coming-soon {
    opacity: 0.55;
  }

  .belt-card-header {
    display: flex;
    align-items: flex-start;
    gap: 14px;
  }

  .belt-indicator {
    flex-shrink: 0;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: var(--belt-color);
    margin-top: 4px;
  }

  .belt-meta {
    flex: 1;
  }

  .belt-name {
    font-size: 17px;
    font-weight: 700;
    color: #111827;
    margin: 0 0 3px;
  }

  .belt-subtitle {
    margin: 0;
    font-size: 14px;
    color: #6b7280;
    line-height: 1.4;
  }

  .coming-soon-badge {
    flex-shrink: 0;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    padding: 3px 8px;
    border-radius: 10px;
    background: #f3f4f6;
    color: #4b5563;
    border: 1px solid #e5e7eb;
  }

  .belt-lessons {
    margin-top: 16px;
    border-top: 1px solid #f3f4f6;
    padding-top: 14px;
  }
</style>
