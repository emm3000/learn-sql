---
import PlaygroundIsland from '../components/Playground.svelte';
import { lesson01Exercises } from '../lib/exercises/lesson-01.ts';
import seedSql from '../../seed/classic_company.sql?raw';
import BaseLayout from '../layouts/BaseLayout.astro';

const exercise = lesson01Exercises[0];
---

<BaseLayout
  title="SQL Playground"
  description="Write SQL against a real PostgreSQL database running in your browser."
>
  <header>
    <h1>SQL Playground</h1>
    <p>Write SQL against a real PostgreSQL database running in your browser.</p>
  </header>
  <main id="main-content" tabindex="-1">
    <PlaygroundIsland
      seedSql={seedSql}
      exercise={exercise}
      client:only="svelte"
    />
  </main>
</BaseLayout>

<style>
  header {
    margin-bottom: 24px;
  }

  h1 {
    font-size: 24px;
    font-weight: 700;
    margin: 0 0 6px;
    color: #111827;
  }

  header p {
    margin: 0;
    color: #6b7280;
    font-size: 15px;
  }

  main {
    /* TODO(reskin): temporary gutter until this page is reskinned */
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 10px;
    padding: 20px;
    max-width: 960px;
    margin: 24px auto;
    width: calc(100% - 32px);
  }
</style>
