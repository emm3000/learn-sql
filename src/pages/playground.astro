---
import PlaygroundIsland from '../components/Playground.svelte';
import { lesson01Exercises } from '../lib/exercises/lesson-01.ts';
import seedSql from '../../seed/classic_company.sql?raw';
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/playground.css';

const exercise = lesson01Exercises[0];
---

<BaseLayout
  title="SQL Playground"
  description="Write SQL against a real PostgreSQL database running in your browser."
>
  <header class="pg-page-header">
    <h1 class="pg-page-title">SQL Playground</h1>
    <p class="pg-page-desc">Write SQL against a real PostgreSQL database running in your browser.</p>
  </header>

  <main id="main-content" tabindex="-1" class="pg-page-main">
    <!-- Prompt displayed on the standalone page (in lesson context,
         LessonExercises.svelte owns the prompt rendering) -->
    <div class="pg-page-prompt">
      <p>{exercise.prompt}</p>
    </div>

    <PlaygroundIsland
      seedSql={seedSql}
      exercise={exercise}
      client:only="svelte"
    />
  </main>
</BaseLayout>

<style>
  .pg-page-header {
    margin-bottom: 24px;
  }

  .pg-page-title {
    font-family: var(--f-serif);
    font-size: 28px;
    font-weight: 700;
    margin: 0 0 6px;
    color: var(--ink);
    letter-spacing: -0.02em;
  }

  .pg-page-desc {
    margin: 0;
    color: var(--ink-2);
    font-family: var(--f-ui);
    font-size: 15px;
    line-height: 1.5;
  }

  .pg-page-main {
    max-width: 960px;
    margin: 0 auto;
    width: calc(100% - 32px);
  }

  .pg-page-prompt {
    margin-bottom: 16px;
    padding: 12px 16px;
    background: var(--surface);
    border: 1px solid var(--line-2);
    border-left: 3px solid var(--beginner);
    border-radius: var(--r-sm);
    font-family: var(--f-ui);
    font-size: 15px;
    line-height: 1.55;
    color: var(--ink);
  }

  .pg-page-prompt p {
    margin: 0;
  }
</style>
